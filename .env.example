# ============================================================
# Adam Takip - Environment Variables
# Dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# ============================================================

# ── Microsoft Entra ID (Azure AD) ──────────────────────────
# Azure Portal > App registrations > Uygulamanız > Overview
AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Azure Portal > App registrations > Uygulamanız > Certificates & secrets
AZURE_AD_CLIENT_SECRET=your-client-secret-here
# Azure Portal > App registrations > Uygulamanız > Overview > Directory (tenant) ID
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Bu değerler MSAL.js için tarayıcıya açık olabilir
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Supabase ────────────────────────────────────────────────
# Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://cbncxiphzfzdmbsvzswy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNibmN4aXBoemZ6ZG1ic3Z6c3d5Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTEwNzMwNiwiZXhwIjoyMDkwNjgzMzA2fQ.cpdlwyM3brhGYeZiuMgam_izxex6LxG18I5PjGv2wEA

# ── Session ─────────────────────────────────────────────────
# Rastgele 32-byte hex: openssl rand -hex 32
SESSION_SECRET=your-random-32-byte-hex-secret-here

# ── Uygulama URL'i ──────────────────────────────────────────
# Local geliştirme için http://localhost:3000
# Production için https://adamtakip.vercel.app (veya özel domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Microsoft Graph Email ───────────────────────────────────
# Email gönderilecek posta kutusu (Azure'da Mail.Send yetkisi olmalı)
# Örn: noreply@cemre.com.tr veya bildirim@cemre.com.tr
GRAPH_SENDER_EMAIL=noreply@cemre.com.tr

# ============================================================
# Azure App Registration - Gerekli Ayarlar:
# ─────────────────────────────────────────
# 1. Authentication > Redirect URIs:
#    - http://localhost:3000/api/auth/callback (development)
#    - https://adamtakip.vercel.app/api/auth/callback (production)
#
# 2. Authentication > Supported account types:
#    - "Accounts in this organizational directory only (Single tenant)"
#
# 3. API Permissions (Application permissions):
#    - Mail.Send (email bildirimleri için)
#    Admin consent gerekli!
#
# 4. API Permissions (Delegated permissions):
#    - openid, profile, email, User.Read
# ============================================================
